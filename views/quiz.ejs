<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Answer quiz questions and test your knowledge. Timer, live score tracking, and instant feedback.">
  <title>Quiz Challenge — Quiz Master</title>
  <link rel="stylesheet" href="styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
  <div class="app-wrapper">
    <!-- Top Bar -->
    <div class="top-bar">
      <a href="/" class="logo">
        <div class="logo-icon"><i class="fas fa-brain"></i></div>
        Quiz Master
      </a>
      <div style="display:flex;gap:8px;align-items:center;">
        <div class="live-score" id="liveScore">
          <i class="fas fa-star"></i>
          <span id="liveScoreValue">0</span>
        </div>
        <button id="soundToggle" class="sound-toggle" onclick="SoundManager.toggle()" title="Toggle Sound">
          <i class="fas fa-volume-high"></i>
        </button>
        <button id="themeToggle" class="theme-toggle" onclick="ThemeManager.toggle()" title="Toggle Dark Mode">
          <i class="fas fa-moon"></i>
        </button>
      </div>
    </div>

    <!-- Main Card -->
    <div class="container">
      <!-- Quiz Header -->
      <div class="quiz-header">
        <div class="question-counter">
          <div class="question-number">
            <i class="fas fa-list-ol"></i>
            Question <span id="current">1</span> of <span id="total">10</span>
          </div>
          <div class="timer" id="timer">
            <i class="fas fa-stopwatch"></i>
            <span>0:00</span>
          </div>
        </div>

        <div class="badge-row">
          <div id="categoryBadge" class="question-category"></div>
          <div id="difficultyBadge" class="difficulty-badge"></div>
        </div>

        <!-- Per-question countdown timer -->
        <div class="per-question-timer" id="questionTimer">30</div>

        <div class="progress-bar">
          <div id="progress" class="progress"></div>
        </div>
      </div>

      <!-- Question -->
      <div class="quiz-content" id="quizContent">
        <h3 id="question" class="question-text">Loading question…</h3>
        <div id="answers" class="answers-container"></div>
      </div>

      <!-- Controls -->
      <div class="quiz-controls">
        <button id="prevBtn" class="btn btn-ghost btn-nav" onclick="previousQuestion()" style="display:none;">
          <i class="fas fa-chevron-left"></i> Previous
        </button>
        <button id="nextBtn" class="btn btn-primary btn-nav" onclick="nextQuestion()">
          Next <i class="fas fa-chevron-right"></i>
        </button>
        <button id="submitBtn" class="btn btn-accent btn-submit" onclick="submitQuiz()" style="display:none;">
          <i class="fas fa-check-circle"></i> Submit Quiz
        </button>
      </div>
    </div>
  </div>

  <script src="app.js"></script>
  <script>
    let questions = [];
    let currentQuestion = 0;
    let userAnswers = [];
    let startTime = 0;
    let timerInterval = null;
    let questionTimerInterval = null;
    let questionTimeLeft = 30;
    let liveScoreCount = 0;
    const QUESTION_TIME = 30; // seconds per question

    window.addEventListener('DOMContentLoaded', () => {
      const stored = localStorage.getItem('questions');
      if (!stored) { window.location.href = '/'; return; }

      questions = JSON.parse(stored);
      userAnswers = new Array(questions.length).fill(null);
      startTime = parseInt(localStorage.getItem('quizStartTime') || Date.now());

      displayQuestion();
      startGlobalTimer();
    });

    // ─── Global elapsed timer ───────────────────────
    function startGlobalTimer() {
      if (timerInterval) clearInterval(timerInterval);
      timerInterval = setInterval(() => {
        const elapsed = Math.floor((Date.now() - startTime) / 1000);
        const m = Math.floor(elapsed / 60);
        const s = elapsed % 60;
        const el = document.getElementById('timer');
        el.innerHTML = `<i class="fas fa-stopwatch"></i> <span>${m}:${s.toString().padStart(2, '0')}</span>`;
      }, 1000);
    }

    // ─── Per-question countdown timer ───────────────
    function startQuestionTimer() {
      if (questionTimerInterval) clearInterval(questionTimerInterval);
      questionTimeLeft = QUESTION_TIME;
      const el = document.getElementById('questionTimer');
      el.textContent = questionTimeLeft;
      el.classList.remove('danger');

      questionTimerInterval = setInterval(() => {
        questionTimeLeft--;
        el.textContent = questionTimeLeft;

        if (questionTimeLeft <= 5) {
          el.classList.add('danger');
          SoundManager.play('tick');
        }

        if (questionTimeLeft <= 0) {
          clearInterval(questionTimerInterval);
          SoundManager.play('timeout');
          // Auto-advance
          if (currentQuestion < questions.length - 1) {
            nextQuestion();
          } else {
            submitQuiz();
          }
        }
      }, 1000);
    }

    // ─── Display question ───────────────────────────
    function displayQuestion() {
      const q = questions[currentQuestion];

      // Animate content transition
      const content = document.getElementById('quizContent');
      content.style.opacity = '0';
      content.style.transform = 'translateX(20px)';

      setTimeout(() => {
        document.getElementById('question').textContent = q.question;
        document.getElementById('current').textContent = currentQuestion + 1;
        document.getElementById('total').textContent = questions.length;

        // Badges
        const catBadge = document.getElementById('categoryBadge');
        catBadge.innerHTML = '<i class="fas fa-tag"></i> ' + q.category;

        const diffBadge = document.getElementById('difficultyBadge');
        diffBadge.className = 'difficulty-badge difficulty-' + q.difficulty;
        diffBadge.textContent = q.difficulty.charAt(0).toUpperCase() + q.difficulty.slice(1);

        // Shuffle answers (store in data attribute to keep consistent)
        let allAnswers;
        if (!q._shuffled) {
          allAnswers = [...q.incorrect_answers, q.correct_answer].sort(() => Math.random() - 0.5);
          q._shuffled = allAnswers;
        } else {
          allAnswers = q._shuffled;
        }

        const answersDiv = document.getElementById('answers');
        answersDiv.innerHTML = '';

        allAnswers.forEach((answer) => {
          const label = document.createElement('label');
          label.className = 'answer-label';
          if (userAnswers[currentQuestion] === answer) {
            label.classList.add('selected');
          }
          label.innerHTML = `
            <input type="radio" name="answer" value="${answer}" ${userAnswers[currentQuestion] === answer ? 'checked' : ''} onchange="handleAnswerChange(this)">
            <span>${answer}</span>
          `;
          answersDiv.appendChild(label);
        });

        // Button visibility
        document.getElementById('prevBtn').style.display = currentQuestion > 0 ? 'inline-flex' : 'none';
        document.getElementById('nextBtn').style.display = currentQuestion < questions.length - 1 ? 'inline-flex' : 'none';
        document.getElementById('submitBtn').style.display = currentQuestion === questions.length - 1 ? 'inline-flex' : 'none';

        // Progress
        const pct = ((currentQuestion + 1) / questions.length) * 100;
        document.getElementById('progress').style.width = pct + '%';

        // Animate in
        content.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
        content.style.opacity = '1';
        content.style.transform = 'translateX(0)';

        // Start per-question timer
        startQuestionTimer();
      }, 150);
    }

    // ─── Answer selection ───────────────────────────
    function handleAnswerChange(el) {
      userAnswers[currentQuestion] = el.value;
      SoundManager.play('click');

      document.querySelectorAll('.answer-label').forEach(l => l.classList.remove('selected'));
      el.parentElement.classList.add('selected');

      // Update live score
      updateLiveScore();
    }

    function updateLiveScore() {
      liveScoreCount = 0;
      questions.forEach((q, i) => {
        if (userAnswers[i] === q.correct_answer) liveScoreCount++;
      });
      document.getElementById('liveScoreValue').textContent = liveScoreCount;
    }

    // ─── Navigation ─────────────────────────────────
    function nextQuestion() {
      if (currentQuestion < questions.length - 1) {
        currentQuestion++;
        displayQuestion();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    function previousQuestion() {
      if (currentQuestion > 0) {
        currentQuestion--;
        displayQuestion();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    // ─── Submit ─────────────────────────────────────
    function submitQuiz() {
      const selected = document.querySelector('input[name="answer"]:checked');
      if (selected) userAnswers[currentQuestion] = selected.value;

      clearInterval(timerInterval);
      clearInterval(questionTimerInterval);

      let score = 0;
      questions.forEach((q, i) => {
        if (userAnswers[i] === q.correct_answer) score++;
      });

      const percentage = Math.round((score / questions.length) * 100);
      const timeTaken = Math.floor((Date.now() - startTime) / 1000);

      localStorage.setItem('score', score);
      localStorage.setItem('total', questions.length);
      localStorage.setItem('percentage', percentage);
      localStorage.setItem('timeTaken', timeTaken);
      localStorage.setItem('userAnswers', JSON.stringify(userAnswers));

      // Save stats
      const stats = JSON.parse(localStorage.getItem('quizStats') || '{"quizzes":[],"taken":0}');
      const categoryStatsStore = JSON.parse(localStorage.getItem('categoryStats') || '{}');

      stats.quizzes.push({
        date: new Date().toLocaleDateString(),
        time: new Date().toLocaleTimeString(),
        score, total: questions.length, percentage, timeTaken,
        category: questions[0].category || 'General'
      });
      stats.taken = stats.quizzes.length;
      localStorage.setItem('quizStats', JSON.stringify(stats));

      // Category stats
      const cat = questions[0].category || 'General';
      if (!categoryStatsStore[cat]) {
        categoryStatsStore[cat] = { attempts: 0, totalScore: 0, bestScore: 0 };
      }
      categoryStatsStore[cat].attempts++;
      categoryStatsStore[cat].totalScore += percentage;
      categoryStatsStore[cat].bestScore = Math.max(categoryStatsStore[cat].bestScore, percentage);
      localStorage.setItem('categoryStats', JSON.stringify(categoryStatsStore));

      // Update high score
      const isNewHighScore = HighScore.update(percentage);
      if (isNewHighScore) {
        localStorage.setItem('newHighScore', 'true');
      }

      // Add to leaderboard
      const playerName = localStorage.getItem('playerName') || 'Player';
      Leaderboard.add(playerName, score, questions.length, percentage);

      SoundManager.play('complete');

      setTimeout(() => { window.location.href = '/result'; }, 350);
    }
  </script>
</body>
</html>
