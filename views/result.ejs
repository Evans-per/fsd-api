<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="View your quiz results, review answers, and track your performance.">
  <title>Results — Quiz Master</title>
  <link rel="stylesheet" href="styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
  <div class="app-wrapper">
    <!-- Top Bar -->
    <div class="top-bar">
      <a href="/" class="logo">
        <div class="logo-icon"><i class="fas fa-brain"></i></div>
        Quiz Master
      </a>
      <div style="display:flex;gap:8px;">
        <button id="soundToggle" class="sound-toggle" onclick="SoundManager.toggle()" title="Toggle Sound">
          <i class="fas fa-volume-high"></i>
        </button>
        <button id="themeToggle" class="theme-toggle" onclick="ThemeManager.toggle()" title="Toggle Dark Mode">
          <i class="fas fa-moon"></i>
        </button>
      </div>
    </div>

    <!-- Main Card -->
    <div class="container" style="max-width:960px;">
      <h1 class="page-title"><i class="fas fa-flag-checkered"></i> Quiz Complete!</h1>

      <!-- Score Ring -->
      <div class="result-card">
        <div class="result-emoji" id="emoji"></div>

        <div class="score-ring-wrapper">
          <svg class="score-ring" width="100%" height="100%" viewBox="0 0 160 160">
            <defs>
              <linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#6366f1"/>
                <stop offset="100%" stop-color="#8b5cf6"/>
              </linearGradient>
            </defs>
            <circle class="score-ring-bg" cx="80" cy="80" r="70"/>
            <circle class="score-ring-fill" id="scoreRingFill" cx="80" cy="80" r="70"/>
          </svg>
          <div class="score-ring-text">
            <div class="score-ring-value" id="ringPercentage">0%</div>
            <div class="score-ring-label">Accuracy</div>
          </div>
        </div>

        <div class="score-fraction">
          <span id="score">0</span> / <span id="total">10</span>
        </div>
        <p class="result-message" id="message">Great Job!</p>

        <div id="highScoreBanner" style="display:none;margin-top:16px;padding:10px 20px;border-radius:var(--radius-full);background:linear-gradient(135deg,#f59e0b,#ef4444);color:white;font-weight:700;font-size:0.95rem;display:inline-flex;align-items:center;gap:8px;">
          <i class="fas fa-crown"></i> New High Score!
        </div>
      </div>

      <!-- Statistics -->
      <div class="stats-section">
        <div class="stats-title">
          <i class="fas fa-chart-bar"></i>
          Quiz Statistics
        </div>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-card-value" id="timeTaken">0s</div>
            <div class="stat-card-label">Time Taken</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-value" id="correctCount">0</div>
            <div class="stat-card-label">Correct</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-value" id="accuracy">0%</div>
            <div class="stat-card-label">Accuracy</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-value" id="avgTime">0s</div>
            <div class="stat-card-label">Avg / Question</div>
          </div>
        </div>
      </div>

      <!-- Performance Rating -->
      <div class="stats-section">
        <div class="stats-title">
          <i class="fas fa-medal"></i>
          Performance Rating
        </div>
        <div style="padding:12px 0;">
          <div class="performance-bar-track">
            <div class="performance-bar-fill" id="performanceLevel"></div>
          </div>
          <div class="performance-text" id="performanceText"></div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="quiz-controls" style="margin-top:32px;">
        <button class="btn btn-ghost" onclick="shareResults()" id="shareBtn">
          <i class="fas fa-share-alt"></i> Share
        </button>
        <button class="btn btn-ghost" onclick="viewAnswers()" id="reviewBtn">
          <i class="fas fa-list-check"></i> Review
        </button>
        <button class="btn btn-primary" onclick="window.location.href='/'" id="retryBtn">
          <i class="fas fa-rotate-right"></i> New Quiz
        </button>
      </div>
    </div>
  </div>

  <!-- Review Modal -->
  <div id="reviewModal" class="modal-overlay">
    <div class="modal-inner">
      <h2><i class="fas fa-book-open" style="color:var(--primary-500);margin-right:8px;"></i> Answer Review</h2>
      <div id="reviewContent"></div>
      <button class="btn btn-primary" onclick="closeReview()" style="width:100%;margin-top:24px;">
        <i class="fas fa-times-circle"></i> Close Review
      </button>
    </div>
  </div>

  <script src="app.js"></script>
  <script>
    let questions = [];

    window.addEventListener('DOMContentLoaded', () => {
      const score = parseInt(localStorage.getItem('score') || 0);
      const total = parseInt(localStorage.getItem('total') || 10);
      const percentage = parseInt(localStorage.getItem('percentage') || 0);
      const timeTaken = parseInt(localStorage.getItem('timeTaken') || 0);
      const questionsStr = localStorage.getItem('questions');
      if (questionsStr) questions = JSON.parse(questionsStr);

      document.getElementById('score').textContent = score;
      document.getElementById('total').textContent = total;
      document.getElementById('correctCount').textContent = score;
      document.getElementById('accuracy').textContent = percentage + '%';

      // Format time
      const m = Math.floor(timeTaken / 60);
      const s = timeTaken % 60;
      document.getElementById('timeTaken').textContent = m > 0 ? m + 'm ' + s + 's' : s + 's';
      document.getElementById('avgTime').textContent = Math.round(timeTaken / total) + 's';

      // Animated ring
      document.getElementById('ringPercentage').textContent = percentage + '%';
      const circumference = 2 * Math.PI * 70; // r=70
      const offset = circumference - (percentage / 100) * circumference;
      const ring = document.getElementById('scoreRingFill');
      ring.style.strokeDasharray = circumference;
      ring.style.strokeDashoffset = circumference;
      setTimeout(() => { ring.style.strokeDashoffset = offset; }, 200);

      // Emoji & message
      let iconHtml, message;
      if (percentage >= 90)      { iconHtml = '<i class="fas fa-trophy" style="color:#f59e0b;"></i>'; message = '🎉 Outstanding! You\'re a Quiz Master!'; }
      else if (percentage >= 80) { iconHtml = '<i class="fas fa-star" style="color:#6366f1;"></i>';  message = '⭐ Excellent! Great knowledge!'; }
      else if (percentage >= 70) { iconHtml = '<i class="fas fa-face-smile" style="color:#22c55e;"></i>'; message = '😊 Very good! Keep it up!'; }
      else if (percentage >= 60) { iconHtml = '<i class="fas fa-thumbs-up" style="color:#14b8a6;"></i>';  message = '👍 Good effort! Try again!'; }
      else                       { iconHtml = '<i class="fas fa-lightbulb" style="color:#f59e0b;"></i>'; message = '💡 Keep learning! You\'ll improve!'; }

      document.getElementById('emoji').innerHTML = iconHtml;
      document.getElementById('message').textContent = message;

      // Performance bar
      setTimeout(() => {
        document.getElementById('performanceLevel').style.width = percentage + '%';
      }, 300);

      let perfText;
      if (percentage >= 90)      perfText = '⭐ Excellent';
      else if (percentage >= 80) perfText = '✓ Very Good';
      else if (percentage >= 70) perfText = '◐ Good';
      else if (percentage >= 60) perfText = '△ Fair';
      else                       perfText = '△ Needs Improvement';
      document.getElementById('performanceText').textContent = perfText;

      // High score banner
      const isNew = localStorage.getItem('newHighScore') === 'true';
      if (isNew) {
        document.getElementById('highScoreBanner').style.display = 'inline-flex';
        localStorage.removeItem('newHighScore');
      }

      // Confetti for great scores
      if (percentage >= 80) {
        setTimeout(() => Confetti.launch(), 500);
      }

      // Sound
      if (percentage >= 70) {
        SoundManager.play('correct');
      }
    });

    // ─── Review answers ─────────────────────────────
    function viewAnswers() {
      const userAnswers = JSON.parse(localStorage.getItem('userAnswers') || '[]');
      const reviewContent = document.getElementById('reviewContent');
      reviewContent.innerHTML = '';

      questions.forEach((q, idx) => {
        const isCorrect = userAnswers[idx] === q.correct_answer;
        const item = document.createElement('div');
        item.className = 'review-item ' + (isCorrect ? 'correct' : 'wrong');

        item.innerHTML = `
          <div class="review-question">
            <div class="review-status-icon ${isCorrect ? 'correct' : 'wrong'}">
              <i class="fas ${isCorrect ? 'fa-check' : 'fa-times'}"></i>
            </div>
            <div>Q${idx + 1}: ${q.question}</div>
          </div>
          <div class="review-answer">
            <strong>Your answer:</strong>
            <span class="${isCorrect ? 'correct-text' : 'wrong-text'}">
              ${userAnswers[idx] || '<em>Not answered</em>'}
            </span>
          </div>
          ${!isCorrect ? `
            <div class="review-answer">
              <strong>Correct answer:</strong>
              <span class="correct-text">${q.correct_answer}</span>
            </div>
          ` : ''}
        `;
        reviewContent.appendChild(item);
      });

      document.getElementById('reviewModal').classList.add('active');
      SoundManager.play('click');
    }

    function closeReview() {
      document.getElementById('reviewModal').classList.remove('active');
    }

    // Close modal on overlay click
    document.getElementById('reviewModal').addEventListener('click', function(e) {
      if (e.target === this) closeReview();
    });

    // ─── Share results ──────────────────────────────
    function shareResults() {
      const score = document.getElementById('score').textContent;
      const total = document.getElementById('total').textContent;
      const pct = document.getElementById('accuracy').textContent;
      const msg = `🎯 I scored ${score}/${total} (${pct}) on Quiz Master! Can you beat me?`;

      navigator.clipboard.writeText(msg).then(() => {
        Toast.show('Results copied to clipboard! 📋', 'success');
        SoundManager.play('correct');
      }).catch(() => {
        Toast.show('Score: ' + score + '/' + total + ' (' + pct + ')', 'info');
      });
    }
  </script>
</body>
</html>
