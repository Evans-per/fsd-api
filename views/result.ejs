<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Results - Quiz Master</title>
  <link rel="stylesheet" href="styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="container result-container">
    <h1><i class="fas fa-flag-checkered"></i> Quiz Complete!</h1>
    
    <div class="result-card">
      <div class="result-emoji" id="emoji"></div>
      <h2>Your Score</h2>
      
      <div class="score-fraction">
        <span id="score">0</span> / <span id="total">10</span>
      </div>
      
      <div id="percentage">0%</div>
      <p id="message">Great Job!</p>
    </div>

    <div class="stats-section">
      <div class="stats-title">
        <i class="fas fa-chart-bar"></i>
        Quiz Statistics
      </div>
      <div class="stat-item">
        <span class="stat-label"><i class="fas fa-clock"></i> Time Taken:</span>
        <span class="stat-value" id="timeTaken">0s</span>
      </div>
      <div class="stat-item">
        <span class="stat-label"><i class="fas fa-check"></i> Correct Answers:</span>
        <span class="stat-value" id="correctCount">0</span>
      </div>
      <div class="stat-item">
        <span class="stat-label"><i class="fas fa-bullseye"></i> Accuracy:</span>
        <span class="stat-value" id="accuracy">0%</span>
      </div>
      <div class="stat-item">
        <span class="stat-label"><i class="fas fa-tachometer-alt"></i> Avg Time/Question:</span>
        <span class="stat-value" id="avgTime">0s</span>
      </div>
    </div>

    <div class="stats-section">
      <div class="stats-title">
        <i class="fas fa-medal"></i>
        Performance Rating
      </div>
      <div style="text-align: center; padding: 25px 0;">
        <div id="performanceBar" style="background: rgba(102, 126, 234, 0.1); height: 16px; border-radius: 20px; position: relative; overflow: hidden; border: 2px solid rgba(102, 126, 234, 0.2);">
          <div id="performanceLevel" style="height: 100%; background: linear-gradient(90deg, #667eea 0%, #764ba2 50%, #f093fb 100%); width: 0%; border-radius: 18px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);"></div>
        </div>
        <p id="performanceText" style="margin-top: 18px; font-size: 1.3em; font-weight: 800; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"></p>
      </div>
    </div>

    <div class="quiz-controls" style="margin-top: 40px;">
      <button class="btn btn-secondary" onclick="viewAnswers()">
        <i class="fas fa-list-check"></i>
        Review Answers
      </button>
      <button class="btn" onclick="window.location.href='/'">
        <i class="fas fa-sync-alt"></i>
        Try Another Quiz
      </button>
    </div>
  </div>

  <!-- Answer Review Modal -->
  <div id="reviewModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(5px); z-index: 1000; overflow-y: auto; padding: 20px;">
    <div class="container" style="margin: 30px auto; max-width: 900px;">
      <h2 style="margin-bottom: 30px; text-align: center;">
        <i class="fas fa-book-open"></i>
        Answer Review
      </h2>
      <div id="reviewContent"></div>
      <button class="btn" onclick="closeReview()" style="width: 100%; margin-top: 30px;">
        <i class="fas fa-times-circle"></i>
        Close Review
      </button>
    </div>
  </div>

  <script>
    let questions = [];

    window.onload = () => {
      const score = parseInt(localStorage.getItem('score') || 0);
      const total = parseInt(localStorage.getItem('total') || 10);
      const percentage = parseInt(localStorage.getItem('percentage') || 0);
      const timeTaken = parseInt(localStorage.getItem('timeTaken') || 0);
      const questionsStr = localStorage.getItem('questions');
      
      if (questionsStr) {
        questions = JSON.parse(questionsStr);
      }

      document.getElementById('score').textContent = score;
      document.getElementById('total').textContent = total;
      document.getElementById('percentage').textContent = percentage + '%';
      document.getElementById('correctCount').textContent = score + ' out of ' + total;
      document.getElementById('accuracy').textContent = percentage + '%';

      // Format time
      const minutes = Math.floor(timeTaken / 60);
      const seconds = timeTaken % 60;
      document.getElementById('timeTaken').textContent = minutes > 0 ? minutes + 'm ' + seconds + 's' : seconds + 's';

      // Average time per question
      const avgTime = Math.round(timeTaken / total);
      document.getElementById('avgTime').textContent = avgTime + 's';

      // Set icon and message
      let icon = '<i class="fas fa-smile"></i>';
      let message = 'Good Job!';
      
      if (percentage >= 90) {
        icon = '<i class="fas fa-trophy"></i>';
        message = '🎉 Outstanding! You are a Quiz Master!';
      } else if (percentage >= 80) {
        icon = '<i class="fas fa-star"></i>';
        message = '⭐ Excellent! Great Knowledge!';
      } else if (percentage >= 70) {
        icon = '<i class="fas fa-smile"></i>';
        message = '😊 Very Good! Keep it up!';
      } else if (percentage >= 60) {
        icon = '<i class="fas fa-thumbs-up"></i>';
        message = '👍 Good Effort! Try Again!';
      } else {
        icon = '<i class="fas fa-lightbulb"></i>';
        message = '💡 Keep Learning! You\'ll do better next time!';
      }

      document.getElementById('emoji').innerHTML = icon;
      document.getElementById('message').textContent = message;

      // Animate performance bar
      setTimeout(() => {
        document.getElementById('performanceLevel').style.width = percentage + '%';
      }, 200);
      
      let performanceText = 'Average';
      if (percentage >= 90) performanceText = '⭐ Excellent';
      else if (percentage >= 80) performanceText = '✓ Very Good';
      else if (percentage >= 70) performanceText = '◐ Good';
      else if (percentage >= 60) performanceText = '△ Fair';
      else performanceText = '△ Needs Improvement';
      
      document.getElementById('performanceText').textContent = performanceText;
    };

    function viewAnswers() {
      const userAnswers = JSON.parse(localStorage.getItem('userAnswers') || '[]');
      const reviewContent = document.getElementById('reviewContent');
      reviewContent.innerHTML = '';

      questions.forEach((q, idx) => {
        const isCorrect = userAnswers[idx] === q.correct_answer;
        const icon = isCorrect ? '✓' : '✗';
        const bgColor = isCorrect ? 'linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%)' : 'linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(239, 68, 68, 0.05) 100%)';
        const borderColor = isCorrect ? 'rgba(16, 185, 129, 0.3)' : 'rgba(239, 68, 68, 0.3)';
        
        const reviewItem = document.createElement('div');
        reviewItem.style.cssText = `
          margin-bottom: 18px;
          padding: 18px;
          border-radius: 14px;
          background: ${bgColor};
          border-left: 5px solid ${isCorrect ? '#10b981' : '#ef4444'};
          transition: all 0.3s ease;
          border: 2px solid ${borderColor};
        `;
        
        const statusColor = isCorrect ? '#10b981' : '#ef4444';
        
        reviewItem.innerHTML = `
          <p style="font-weight: 800; margin-bottom: 12px; color: #1e293b; font-size: 1.05em;">
            <span style="color: ${statusColor}; font-size: 1.2em; margin-right: 8px;">${icon}</span>
            Question ${idx + 1}: ${q.question}
          </p>
          <p style="margin: 10px 0; color: #475569;">
            <strong style="color: #1e293b;">Your Answer:</strong> 
            <span style="color: ${isCorrect ? '#10b981' : '#ef4444'}; font-weight: 600;">
              ${userAnswers[idx] || '<i>Not Answered</i>'}
            </span>
          </p>
          ${!isCorrect ? `
            <p style="margin: 10px 0; color: #475569;">
              <strong style="color: #1e293b;">Correct Answer:</strong> 
              <span style="color: #10b981; font-weight: 600;">${q.correct_answer}</span>
            </p>
          ` : ''}
        `;
        
        reviewContent.appendChild(reviewItem);
      });

      document.getElementById('reviewModal').style.display = 'block';
    }

    function closeReview() {
      document.getElementById('reviewModal').style.display = 'none';
    }

    // Close modal on outside click
    window.onclick = function(event) {
      const modal = document.getElementById('reviewModal');
      if (event.target == modal) {
        modal.style.display = 'none';
      }
    }
  </script>
</body>
</html>
