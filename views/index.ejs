<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz Master - Online Quiz Platform</title>
  <link rel="stylesheet" href="styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="container">
    <h1><i class="fas fa-brain"></i> Quiz Master</h1>
    <p class="subtitle">Challenge Your Knowledge • Learn & Grow</p>
    
    <div class="setup-form">
      <div class="form-group">
        <label for="amount">
          <span class="label-icon"><i class="fas fa-hashtag"></i></span>
          Number of Questions
        </label>
        <input type="number" id="amount" min="1" max="50" value="10" placeholder="Enter number of questions">
      </div>
      
      <div class="form-group">
        <label for="category">
          <span class="label-icon"><i class="fas fa-book"></i></span>
          Category
        </label>
        <select id="category">
          <option value="">🎲 Random Category</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="difficulty">
          <span class="label-icon"><i class="fas fa-zap"></i></span>
          Difficulty Level
        </label>
        <select id="difficulty">
          <option value="">📊 Any Difficulty</option>
          <option value="easy">🟢 Easy</option>
          <option value="medium">🟡 Medium</option>
          <option value="hard">🔴 Hard</option>
        </select>
      </div>
      
      <button class="btn" id="startBtn" onclick="startQuiz()">
        <i class="fas fa-play"></i>
        <span id="btnText">Start Quiz</span>
      </button>
    </div>

    <div class="stats-section" id="statsSection" style="display: none;">
      <div class="stats-title">
        <i class="fas fa-chart-line"></i>
        Your Performance
      </div>
      <div class="stat-item">
        <span class="stat-label">📝 Quizzes Completed:</span>
        <span class="stat-value" id="quizzesTaken">0</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">📊 Average Score:</span>
        <span class="stat-value" id="avgScore">0%</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">⭐ Best Score:</span>
        <span class="stat-value" id="bestScore">0%</span>
      </div>
    </div>
  </div>

  <script>
    // Load categories on page load
    window.onload = async () => {
      try {
        const response = await fetch('/api/categories');
        const data = await response.json();
        const categorySelect = document.getElementById('category');
        
        data.trivia_categories.forEach(cat => {
          const option = document.createElement('option');
          option.value = cat.id;
          option.textContent = cat.name;
          categorySelect.appendChild(option);
        });
      } catch (error) {
        console.error('Error loading categories:', error);
      }

      // Load and display stats
      loadStats();
    };

    function loadStats() {
      const stats = JSON.parse(localStorage.getItem('quizStats') || '{"quizzes": [], "taken": 0}');
      if (stats.taken > 0) {
        document.getElementById('statsSection').style.display = 'block';
        document.getElementById('quizzesTaken').textContent = stats.taken;
        
        let totalScore = stats.quizzes.reduce((sum, q) => sum + q.percentage, 0);
        let avgScore = Math.round(totalScore / stats.taken);
        let bestScore = Math.max(...stats.quizzes.map(q => q.percentage));
        
        document.getElementById('avgScore').textContent = avgScore + '%';
        document.getElementById('bestScore').textContent = bestScore + '%';
      }
    }

    async function startQuiz() {
      const amount = document.getElementById('amount').value || 10;
      const category = document.getElementById('category').value;
      const difficulty = document.getElementById('difficulty').value;
      const startBtn = document.getElementById('startBtn');
      const btnText = document.getElementById('btnText');
      
      // Disable button and show loading state
      startBtn.disabled = true;
      startBtn.style.opacity = '0.7';
      btnText.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
      
      try {
        const url = `/api/quiz?amount=${amount}&category=${category}&difficulty=${difficulty}`;
        const response = await fetch(url);
        const data = await response.json();
        
        if (data.success) {
          localStorage.setItem('questions', JSON.stringify(data.questions));
          localStorage.setItem('quizStartTime', Date.now());
          // Add small delay for better UX
          setTimeout(() => {
            window.location.href = '/quiz';
          }, 500);
        } else {
          showError('Failed to start quiz. Please try again!');
          resetButton();
        }
      } catch (error) {
        console.error('Error:', error);
        showError('Error starting quiz. Please check your connection!');
        resetButton();
      }
    }

    function resetButton() {
      const startBtn = document.getElementById('startBtn');
      const btnText = document.getElementById('btnText');
      startBtn.disabled = false;
      startBtn.style.opacity = '1';
      btnText.innerHTML = '<i class="fas fa-play"></i> <span>Start Quiz</span>';
    }

    function showError(message) {
      alert(message);
    }
  </script>
</body>
</html>
