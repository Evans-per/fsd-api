<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Quiz Master — Test your knowledge with thousands of questions across multiple categories and difficulty levels.">
  <title>Quiz Master — Challenge Your Knowledge</title>
  <link rel="stylesheet" href="styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
  <div class="app-wrapper">
    <!-- Top Bar -->
    <div class="top-bar">
      <a href="/" class="logo">
        <div class="logo-icon"><i class="fas fa-brain"></i></div>
        Quiz Master
      </a>
      <div style="display:flex;gap:8px;">
        <button id="soundToggle" class="sound-toggle" onclick="SoundManager.toggle()" title="Toggle Sound">
          <i class="fas fa-volume-high"></i>
        </button>
        <button id="themeToggle" class="theme-toggle" onclick="ThemeManager.toggle()" title="Toggle Dark Mode">
          <i class="fas fa-moon"></i>
        </button>
      </div>
    </div>

    <!-- Main Card -->
    <div class="container">
      <h1 class="page-title"><i class="fas fa-brain"></i> Quiz Master</h1>
      <p class="page-subtitle">Challenge your knowledge · Learn &amp; grow · Compete with yourself</p>

      <div class="setup-form">
        <div class="form-group">
          <label for="amount">
            <span class="label-icon"><i class="fas fa-hashtag"></i></span>
            Number of Questions
          </label>
          <input type="number" id="amount" min="1" max="50" value="10" placeholder="How many questions?">
        </div>

        <div class="form-group">
          <label for="category">
            <span class="label-icon"><i class="fas fa-layer-group"></i></span>
            Category
          </label>
          <select id="category">
            <option value="">🎲 Any Category</option>
          </select>
        </div>

        <div class="form-group">
          <label for="difficulty">
            <span class="label-icon"><i class="fas fa-signal"></i></span>
            Difficulty
          </label>
          <select id="difficulty">
            <option value="">📊 Any Difficulty</option>
            <option value="easy">🟢 Easy</option>
            <option value="medium">🟡 Medium</option>
            <option value="hard">🔴 Hard</option>
          </select>
        </div>

        <button class="btn btn-primary" id="startBtn" onclick="startQuiz()" style="width:100%;margin-top:8px;">
          <i class="fas fa-play"></i>
          <span id="btnText">Start Quiz</span>
        </button>
      </div>

      <!-- Stats Section -->
      <div class="stats-section" id="statsSection" style="display:none;margin-top:32px;">
        <div class="stats-title">
          <i class="fas fa-chart-line"></i>
          Your Performance
        </div>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-card-value" id="quizzesTaken">0</div>
            <div class="stat-card-label">Quizzes</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-value" id="streakDays" style="background:linear-gradient(135deg,#f59e0b,#ef4444);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">0</div>
            <div class="stat-card-label">Day Streak</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-value" id="avgScore">0%</div>
            <div class="stat-card-label">Avg Score</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-value" id="bestScore">0%</div>
            <div class="stat-card-label">Best Score</div>
          </div>
        </div>
        <div id="achievements" class="badges-container" style="margin-top:16px;"></div>
      </div>

      <!-- Category Stats -->
      <div id="categorySection" class="stats-section" style="display:none;margin-top:12px;">
        <div class="stats-title">
          <i class="fas fa-folder-open"></i>
          Category Performance
        </div>
        <div id="categoryStats" class="category-grid"></div>
      </div>

      <!-- Leaderboard -->
      <div class="stats-section" id="leaderboardSection" style="margin-top:12px;">
        <div class="stats-title">
          <i class="fas fa-trophy"></i>
          Leaderboard
        </div>
        <div id="leaderboardContainer"></div>
      </div>
    </div>
  </div>

  <script src="app.js"></script>
  <script>
    // ─── Load categories ────────────────────────────
    window.addEventListener('DOMContentLoaded', async () => {
      try {
        const response = await fetch('/api/categories');
        const data = await response.json();
        const sel = document.getElementById('category');
        data.trivia_categories.forEach(cat => {
          const opt = document.createElement('option');
          opt.value = cat.id;
          opt.textContent = cat.name;
          sel.appendChild(opt);
        });
      } catch (e) {
        console.error('Error loading categories:', e);
      }

      loadStats();
      loadCategoryStats();
      Leaderboard.render('leaderboardContainer');
    });

    // ─── Stats ──────────────────────────────────────
    function loadStats() {
      const stats = JSON.parse(localStorage.getItem('quizStats') || '{"quizzes":[],"taken":0}');
      if (stats.taken > 0) {
        document.getElementById('statsSection').style.display = 'block';
        document.getElementById('quizzesTaken').textContent = stats.taken;

        const totalScore = stats.quizzes.reduce((s, q) => s + q.percentage, 0);
        const avg = Math.round(totalScore / stats.taken);
        const best = Math.max(...stats.quizzes.map(q => q.percentage));

        document.getElementById('avgScore').textContent = avg + '%';
        document.getElementById('bestScore').textContent = best + '%';

        const streak = calculateStreak(stats.quizzes);
        document.getElementById('streakDays').textContent = streak;

        loadAchievements(stats.taken, best, streak);
      }
    }

    function calculateStreak(quizzes) {
      if (quizzes.length === 0) return 0;
      const sorted = [...quizzes].sort((a, b) => new Date(b.date) - new Date(a.date));
      let streak = 0;
      let currentDate = new Date();
      currentDate.setHours(0, 0, 0, 0);

      for (const quiz of sorted) {
        const qd = new Date(quiz.date);
        qd.setHours(0, 0, 0, 0);
        const diff = (currentDate - qd) / (1000 * 60 * 60 * 24);
        if (diff === streak) {
          streak++;
          currentDate.setDate(currentDate.getDate() - 1);
        } else if (diff === 0) {
          streak = 1;
          currentDate.setDate(currentDate.getDate() - 1);
        } else {
          break;
        }
      }
      return streak;
    }

    function loadAchievements(taken, best, streak) {
      const el = document.getElementById('achievements');
      el.innerHTML = '';
      const badges = [];
      if (taken >= 1)   badges.push({ icon: '🎯', name: 'First Step' });
      if (taken >= 5)   badges.push({ icon: '📚', name: 'Quiz Lover' });
      if (taken >= 10)  badges.push({ icon: '🏆', name: 'Champion' });
      if (best >= 90)   badges.push({ icon: '⭐', name: 'Perfect Mind' });
      if (best === 100) badges.push({ icon: '🎆', name: 'Flawless' });
      if (streak >= 3)  badges.push({ icon: '🔥', name: 'On Fire' });
      if (streak >= 7)  badges.push({ icon: '💪', name: 'Unstoppable' });

      badges.forEach(b => {
        const d = document.createElement('div');
        d.className = 'badge';
        d.innerHTML = `<span class="badge-icon">${b.icon}</span> ${b.name}`;
        el.appendChild(d);
      });
    }

    function loadCategoryStats() {
      const cs = JSON.parse(localStorage.getItem('categoryStats') || '{}');
      const section = document.getElementById('categorySection');
      const grid = document.getElementById('categoryStats');

      if (Object.keys(cs).length > 0) {
        section.style.display = 'block';
        grid.innerHTML = '';
        const sorted = Object.entries(cs).sort((a, b) => b[1].bestScore - a[1].bestScore);
        sorted.forEach(([cat, stats]) => {
          const avg = Math.round(stats.totalScore / stats.attempts);
          const card = document.createElement('div');
          card.className = 'category-card';
          card.innerHTML = `
            <div class="category-card-name" title="${cat}">${cat}</div>
            <div class="category-card-score">${avg}%</div>
            <div class="category-card-attempts">${stats.attempts} attempt${stats.attempts > 1 ? 's' : ''}</div>
          `;
          grid.appendChild(card);
        });
      }
    }

    // ─── Start Quiz ─────────────────────────────────
    async function startQuiz() {
      const amount = document.getElementById('amount').value || 10;
      const category = document.getElementById('category').value;
      const difficulty = document.getElementById('difficulty').value;
      const startBtn = document.getElementById('startBtn');
      const btnText = document.getElementById('btnText');

      startBtn.disabled = true;
      btnText.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
      SoundManager.play('click');

      try {
        const url = `/api/quiz?amount=${amount}&category=${category}&difficulty=${difficulty}`;
        const resp = await fetch(url);
        const data = await resp.json();

        if (data.success) {
          localStorage.setItem('questions', JSON.stringify(data.questions));
          localStorage.setItem('quizStartTime', Date.now());
          setTimeout(() => { window.location.href = '/quiz'; }, 400);
        } else {
          Toast.show('Failed to load questions. Try again!', 'error');
          resetButton();
        }
      } catch (e) {
        console.error(e);
        Toast.show('Network error. Check your connection.', 'error');
        resetButton();
      }
    }

    function resetButton() {
      const startBtn = document.getElementById('startBtn');
      const btnText = document.getElementById('btnText');
      startBtn.disabled = false;
      btnText.innerHTML = 'Start Quiz';
    }
  </script>
</body>
</html>
