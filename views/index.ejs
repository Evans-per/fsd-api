<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz Master - Online Quiz Platform</title>
  <link rel="stylesheet" href="styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="container">
    <h1><i class="fas fa-brain"></i> Quiz Master</h1>
    <p class="subtitle">Challenge Your Knowledge • Learn & Grow</p>
    
    <div class="setup-form">
      <div class="form-group">
        <label for="amount">
          <span class="label-icon"><i class="fas fa-hashtag"></i></span>
          Number of Questions
        </label>
        <input type="number" id="amount" min="1" max="50" value="10" placeholder="Enter number of questions">
      </div>
      
      <div class="form-group">
        <label for="category">
          <span class="label-icon"><i class="fas fa-book"></i></span>
          Category
        </label>
        <select id="category">
          <option value="">🎲 Random Category</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="difficulty">
          <span class="label-icon"><i class="fas fa-zap"></i></span>
          Difficulty Level
        </label>
        <select id="difficulty">
          <option value="">📊 Any Difficulty</option>
          <option value="easy">🟢 Easy</option>
          <option value="medium">🟡 Medium</option>
          <option value="hard">🔴 Hard</option>
        </select>
      </div>
      
      <button class="btn" id="startBtn" onclick="startQuiz()">
        <i class="fas fa-play"></i>
        <span id="btnText">Start Quiz</span>
      </button>
    </div>

    <div class="stats-section" id="statsSection" style="display: none;">
      <div class="stats-title">
        <i class="fas fa-chart-line"></i>
        Your Performance
      </div>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
        <div class="stat-item">
          <span class="stat-label">📝 Quizzes:</span>
          <span class="stat-value" id="quizzesTaken">0</span>
        </div>
        <div class="stat-item">
          <span class="stat-label">🔥 Streak:</span>
          <span class="stat-value" id="streakDays" style="color: #f59e0b;">0 days</span>
        </div>
      </div>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
        <div class="stat-item" style="border-bottom: none;">
          <span class="stat-label">📊 Average:</span>
          <span class="stat-value" id="avgScore">0%</span>
        </div>
        <div class="stat-item" style="border-bottom: none;">
          <span class="stat-label">⭐ Best:</span>
          <span class="stat-value" id="bestScore">0%</span>
        </div>
      </div>

      <div id="achievements" style="margin-top: 20px; display: flex; flex-wrap: wrap; gap: 10px;"></div>

      <div id="categorySection" style="margin-top: 25px; display: none;">
        <h3 style="font-size: 1.1em; margin-bottom: 15px; color: #4f46e5;">📂 Category Performance</h3>
        <div id="categoryStats" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px;"></div>
      </div>
    </div>
  </div>

  <script>
    // Load categories on page load
    window.onload = async () => {
      try {
        const response = await fetch('/api/categories');
        const data = await response.json();
        const categorySelect = document.getElementById('category');
        
        data.trivia_categories.forEach(cat => {
          const option = document.createElement('option');
          option.value = cat.id;
          option.textContent = cat.name;
          categorySelect.appendChild(option);
        });
      } catch (error) {
        console.error('Error loading categories:', error);
      }

      // Load and display stats
      loadStats();
      loadCategoryStats();
    };

    function loadStats() {
      const stats = JSON.parse(localStorage.getItem('quizStats') || '{"quizzes": [], "taken": 0}');
      if (stats.taken > 0) {
        document.getElementById('statsSection').style.display = 'block';
        document.getElementById('quizzesTaken').textContent = stats.taken;
        
        let totalScore = stats.quizzes.reduce((sum, q) => sum + q.percentage, 0);
        let avgScore = Math.round(totalScore / stats.taken);
        let bestScore = Math.max(...stats.quizzes.map(q => q.percentage));
        
        document.getElementById('avgScore').textContent = avgScore + '%';
        document.getElementById('bestScore').textContent = bestScore + '%';

        // Calculate streak
        const streak = calculateStreak(stats.quizzes);
        const streakEl = document.getElementById('streakDays');
        if (streak > 0) {
          streakEl.textContent = streak + ' day' + (streak > 1 ? 's' : '');
        }

        // Load achievements
        loadAchievements(stats.taken, bestScore, streak);
      }
    }

    function calculateStreak(quizzes) {
      if (quizzes.length === 0) return 0;
      
      // Sort by date descending
      const sorted = [...quizzes].sort((a, b) => new Date(b.date) - new Date(a.date));
      
      let streak = 0;
      let currentDate = new Date();
      currentDate.setHours(0, 0, 0, 0);
      
      for (let quiz of sorted) {
        const quizDate = new Date(quiz.date);
        quizDate.setHours(0, 0, 0, 0);
        
        const dayDiff = (currentDate - quizDate) / (1000 * 60 * 60 * 24);
        
        if (dayDiff === streak) {
          streak++;
          currentDate.setDate(currentDate.getDate() - 1);
        } else if (dayDiff === 0) {
          // Today's quiz
          streak = 1;
          currentDate.setDate(currentDate.getDate() - 1);
        } else {
          break;
        }
      }
      
      return streak;
    }

    function loadAchievements(quizzesTaken, bestScore, streak) {
      const achievements = document.getElementById('achievements');
      achievements.innerHTML = '';
      
      const badges = [];

      if (quizzesTaken >= 1) badges.push({ icon: '🎯', name: 'First Step', title: 'Completed first quiz' });
      if (quizzesTaken >= 5) badges.push({ icon: '📚', name: 'Quiz Lover', title: 'Completed 5 quizzes' });
      if (quizzesTaken >= 10) badges.push({ icon: '🏆', name: 'Champion', title: 'Completed 10 quizzes' });
      if (bestScore >= 90) badges.push({ icon: '⭐', name: 'Perfect Mind', title: '90%+ score' });
      if (bestScore === 100) badges.push({ icon: '🎆', name: 'Flawless', title: '100% score' });
      if (streak >= 3) badges.push({ icon: '🔥', name: 'On Fire', title: '3-day streak' });
      if (streak >= 7) badges.push({ icon: '💪', name: 'Unstoppable', title: 'Week streak' });

      badges.forEach(badge => {
        const badgeEl = document.createElement('div');
        badgeEl.title = badge.title;
        badgeEl.style.cssText = `
          display: flex;
          align-items: center;
          gap: 6px;
          padding: 8px 12px;
          background: linear-gradient(135deg, rgba(79, 70, 229, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%);
          border: 1px solid rgba(79, 70, 229, 0.2);
          border-radius: 20px;
          font-size: 0.85em;
          font-weight: 700;
          color: #4f46e5;
          cursor: pointer;
          transition: all 0.3s ease;
        `;
        badgeEl.onmouseover = () => {
          badgeEl.style.background = 'linear-gradient(135deg, rgba(79, 70, 229, 0.2) 0%, rgba(6, 182, 212, 0.2) 100%)';
          badgeEl.style.transform = 'scale(1.05)';
        };
        badgeEl.onmouseout = () => {
          badgeEl.style.background = 'linear-gradient(135deg, rgba(79, 70, 229, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%)';
          badgeEl.style.transform = 'scale(1)';
        };
        badgeEl.innerHTML = `<span style="font-size: 1.2em;">${badge.icon}</span> ${badge.name}`;
        achievements.appendChild(badgeEl);
      });
    }

    function loadCategoryStats() {
      const categoryStats = JSON.parse(localStorage.getItem('categoryStats') || '{}');
      const categorySection = document.getElementById('categorySection');
      const categoryStatsDiv = document.getElementById('categoryStats');
      
      if (Object.keys(categoryStats).length > 0) {
        categorySection.style.display = 'block';
        categoryStatsDiv.innerHTML = '';
        
        // Sort by best score
        const sorted = Object.entries(categoryStats).sort((a, b) => b[1].bestScore - a[1].bestScore);
        
        sorted.forEach(([category, stats]) => {
          const avgScore = Math.round(stats.totalScore / stats.attempts);
          const card = document.createElement('div');
          card.style.cssText = `
            padding: 12px;
            background: linear-gradient(135deg, rgba(79, 70, 229, 0.08) 0%, rgba(6, 182, 212, 0.08) 100%);
            border: 1px solid rgba(79, 70, 229, 0.15);
            border-radius: 10px;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
          `;
          card.onmouseover = () => {
            card.style.transform = 'translateY(-4px)';
            card.style.boxShadow = '0 6px 15px rgba(79, 70, 229, 0.2)';
          };
          card.onmouseout = () => {
            card.style.transform = 'translateY(0)';
            card.style.boxShadow = 'none';
          };
          card.innerHTML = `
            <div style="font-size: 0.85em; color: #64748b; margin-bottom: 6px; font-weight: 600;">${category}</div>
            <div style="font-size: 1.5em; font-weight: 800; background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">${avgScore}%</div>
            <div style="font-size: 0.75em; color: #94a3b8; margin-top: 4px;">${stats.attempts} attempt${stats.attempts > 1 ? 's' : ''}</div>
          `;
          categoryStatsDiv.appendChild(card);
        });
      }
    }

    async function startQuiz() {
      const amount = document.getElementById('amount').value || 10;
      const category = document.getElementById('category').value;
      const difficulty = document.getElementById('difficulty').value;
      const startBtn = document.getElementById('startBtn');
      const btnText = document.getElementById('btnText');
      
      // Disable button and show loading state
      startBtn.disabled = true;
      startBtn.style.opacity = '0.7';
      btnText.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
      
      try {
        const url = `/api/quiz?amount=${amount}&category=${category}&difficulty=${difficulty}`;
        const response = await fetch(url);
        const data = await response.json();
        
        if (data.success) {
          localStorage.setItem('questions', JSON.stringify(data.questions));
          localStorage.setItem('quizStartTime', Date.now());
          // Add small delay for better UX
          setTimeout(() => {
            window.location.href = '/quiz';
          }, 500);
        } else {
          showError('Failed to start quiz. Please try again!');
          resetButton();
        }
      } catch (error) {
        console.error('Error:', error);
        showError('Error starting quiz. Please check your connection!');
        resetButton();
      }
    }

    function resetButton() {
      const startBtn = document.getElementById('startBtn');
      const btnText = document.getElementById('btnText');
      startBtn.disabled = false;
      startBtn.style.opacity = '1';
      btnText.innerHTML = '<i class="fas fa-play"></i> <span>Start Quiz</span>';
    }

    function showError(message) {
      alert(message);
    }
  </script>
</body>
</html>
